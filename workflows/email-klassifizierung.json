      "id": "imap-trigger",
      "name": "IMAP Trigger",
      "type": "n8n-nodes-base.emailTrigger",
      "typeVersion": 1.1,
      "position": [220, 300]
    },
    {
      "parameters": {
        "prompt": "Klassifiziere die folgende E-Mail in eine der Kategorien: KUNDE, LIEFERANT, INTERN, SPAM, SONSTIGE.\n\nBetreff: {{$json.subject}}\n\nAbsender: {{$json.from}}\n\nInhalt: {{$json.text}}\n\nAntworte nur mit der Kategorie.",
        "model": "claude-3-5-sonnet-20241022",
        "options": {}
      },
      "id": "claude-classify",
      "name": "KI-Klassifizierung",
      "type": "@anthropic-ai/anthropic",
      "typeVersion": 1,
      "position": [460, 300],
      "credentials": { "anthropicApi": { "id": "CLAUDE_CREDENTIAL_ID", "name": "Claude API" } }
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.message.content[0].text }}",
              "operation": "equals",
              "value2": "KUNDE"
            }
          ]
        }
      },
      "id": "if-node",
      "name": "Kategorie prüfen",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [700, 300]
    },
    {
      "parameters": {
        "channel": "#neue-kundenanfragen",
        "text": "🆕 Neue Kundenanfrage:\n*Von:* {{$node['IMAP Trigger'].json.from}}\n*Betreff:* {{$node['IMAP Trigger'].json.subject}}"
      },
      "id": "slack-notify",
      "name": "Slack Benachrichtigung",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.1,
      "position": [940, 200],
      "credentials": { "slackApi": { "id": "SLACK_CREDENTIAL_ID", "name": "Slack API" } }
    },
    {
      "parameters": {
        "fromEmail": "automatisierung@example.com",
        "toEmail": "={{ $node['IMAP Trigger'].json.from }}",
        "subject": "Vielen Dank für Ihre Anfrage",
        "text": "Guten Tag,\n\nvielen Dank für Ihre Nachricht. Wir werden uns zeitnah bei Ihnen melden.\n\nMit freundlichen Grüßen"
      },
      "id": "auto-reply",
      "name": "Auto-Antwort",
