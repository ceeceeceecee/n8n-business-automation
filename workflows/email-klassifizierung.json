{
  "name": "E-Mail-Klassifizierung",
  "nodes": [
    {
      "parameters": {
        "host": "imap.example.com",
        "port": 993,
        "secure": true,
        "user": "={{ $credentials.imapUser }}",
        "password": "={{ $credentials.imapPassword }}"
